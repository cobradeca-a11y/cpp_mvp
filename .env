# CPP — configuração profissional

# Comando do Audiveris.
# Linux/macOS, se Audiveris estiver no PATH:
AUDIVERIS_CMD=audiveris

# Windows, exemplo:
AUDIVERIS_CMD=C:\Program Files\Audiveris\Audiveris.exe

CPP_BACKEND_HOST=0.0.0.0
CPP_BACKEND_PORT=8787

