<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CPP — Conversor de Partituras Pedagógico</title>
  <link rel="manifest" href="manifest.json" />
  <link rel="stylesheet" href="src/styles.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
</head>
<body>
  <header class="topbar">
    <div>
      <h1>CPP</h1>
      <p>Conversor de Partituras Pedagógico — MVP local/PWA</p>
    </div>
    <div class="status-pill" id="saveStatus">Sessão local pronta</div>
  </header>

  <nav class="tabs" aria-label="Telas do CPP">
    <button data-screen="upload" class="active">1. Upload</button>
    <button data-screen="page">2. Página</button>
    <button data-screen="systems">3. Sistemas/Compassos</button>
    <button data-screen="measure">4. Editor</button>
    <button data-screen="output">5. Saída</button>
  </nav>

  <main>
    <section id="screen-upload" class="screen active">
      <div class="card">
        <h2>1. Upload</h2>
        <p>Carregue PDF, JPG, PNG ou WEBP. O MVP é semiassistido: você marca sistemas, compassos e alinhamentos.</p>
        <div class="upload-box">
          <input id="fileInput" type="file" accept="application/pdf,image/png,image/jpeg,image/webp" />
          <button id="startAnalysisBtn" class="primary">Iniciar análise</button>
        </div>
        <dl class="info-grid">
          <dt>Arquivo</dt><dd id="fileName">—</dd>
          <dt>Tipo</dt><dd id="fileType">—</dd>
          <dt>Páginas</dt><dd id="filePages">—</dd>
          <dt>Qualidade</dt><dd id="qualityNotice">Aguardando arquivo</dd>
        </dl>
      </div>
    </section>

    <section id="screen-page" class="screen">
      <div class="layout two">
        <div class="card">
          <h2>2. Página</h2>
          <div class="toolbar">
            <label>Zoom <input id="pageZoom" type="range" min="0.35" max="2.5" step="0.05" value="1" /></label>
            <button id="newSystemBtn">Selecionar sistema</button>
            <button id="clearSystemsBtn" class="danger">Limpar sistemas</button>
          </div>
          <p class="hint">Clique em “Selecionar sistema”, arraste um retângulo sobre uma linha musical completa e solte.</p>
          <div id="pageCanvasWrap" class="canvas-wrap large"></div>
        </div>
        <aside class="card side">
          <h3>Sistemas</h3>
          <ul id="systemsList" class="list"></ul>
        </aside>
      </div>
    </section>

    <section id="screen-systems" class="screen">
      <div class="layout two">
        <div class="card">
          <h2>3. Sistemas e compassos</h2>
          <div class="toolbar">
            <label>Sistema <select id="systemSelect"></select></label>
            <label>Compasso padrão <select id="meterSelect"><option>3/4</option><option>2/4</option><option>4/4</option></select></label>
            <button id="addBarlineModeBtn">Marcar barra</button>
            <button id="generateMeasuresBtn" class="primary">Gerar compassos</button>
          </div>
          <p class="hint">Clique no sistema para marcar barras. Depois gere os compassos entre as barras.</p>
          <div id="systemCanvasWrap" class="canvas-wrap medium"></div>
        </div>
        <aside class="card side">
          <h3>Barras do sistema</h3>
          <div class="toolbar vertical">
            <label>Tipo <select id="barlineType"><option>simple_barline</option><option>double_barline</option><option>repeat_start</option><option>repeat_end</option><option>final_barline</option></select></label>
          </div>
          <ul id="barlinesList" class="list"></ul>
          <h3>Compassos</h3>
          <ul id="measuresList" class="list"></ul>
        </aside>
      </div>
    </section>

    <section id="screen-measure" class="screen">
      <div class="layout editor-grid">
        <div class="card">
          <h2>4. Editor de compasso</h2>
          <div class="toolbar wrap">
            <label>Compasso <select id="measureSelect"></select></label>
            <label>Zoom <input id="measureZoom" type="range" min="1" max="5" step="0.25" value="2" /></label>
            <label>Lupa <input id="lensZoom" type="range" min="2" max="8" step="0.5" value="4" /></label>
            <label>Tipo <select id="markerType"><option value="chord">chord</option><option value="syllable">syllable</option><option value="note_head">note_head</option><option value="beat">beat</option><option value="rest">rest</option><option value="navigation">navigation</option></select></label>
            <button id="undoBtn">Undo</button>
            <button id="approveMeasureBtn" class="primary">Aprovar compasso</button>
            <button id="pendingMeasureBtn">Marcar pendente</button>
          </div>
          <div id="measureCanvasWrap" class="canvas-wrap editor"></div>
        </div>

        <aside class="card side">
          <h3>Marcadores</h3>
          <ul id="markersList" class="list compact"></ul>
          <h3>Criar alinhamento</h3>
          <div class="form-stack">
            <label>Acorde <select id="alignChord"></select></label>
            <label>Sílaba <select id="alignSyllable"></select></label>
            <label>Nota <select id="alignNote"></select></label>
            <label>Tipo <select id="alignType"><option>chord_on_syllable</option><option>chord_before_syllable</option><option>chord_between_syllables</option><option>chord_on_rest</option><option>chord_at_measure_start</option></select></label>
            <label>Confiança <select id="alignConfidence"><option>certo</option><option>provável</option><option>incerto</option><option>ilegível</option></select></label>
            <label><input id="simultaneousEvent" type="checkbox" /> Evento simultâneo</label>
            <textarea id="alignObservation" placeholder="Observação"></textarea>
            <button id="createAlignmentBtn" class="primary">Criar alinhamento</button>
          </div>
          <h3>Alinhamentos</h3>
          <ul id="alignmentsList" class="list compact"></ul>
        </aside>
      </div>
    </section>

    <section id="screen-output" class="screen">
      <div class="layout two">
        <div class="card">
          <h2>5. Saída</h2>
          <div class="toolbar wrap">
            <button id="generateOutputsBtn" class="primary">Gerar saídas</button>
            <button id="exportJsonBtn">Exportar JSON</button>
            <button id="exportTechnicalBtn">Exportar cifra técnica</button>
            <button id="exportPlayableBtn">Exportar cifra tocável</button>
            <button id="exportReportBtn">Exportar relatório</button>
            <button id="exportAllBtn">Exportar pacote</button>
          </div>
          <div class="output-grid">
            <div><h3>Cifra técnica</h3><pre id="technicalOutput"></pre></div>
            <div><h3>Cifra tocável</h3><pre id="playableOutput"></pre></div>
          </div>
        </div>
        <aside class="card side">
          <h3>Relatório de incertezas</h3>
          <pre id="reportOutput"></pre>
        </aside>
      </div>
    </section>
  </main>

  <template id="modalTemplate">
    <div class="modal-backdrop">
      <div class="modal">
        <h3></h3>
        <div class="modal-body"></div>
        <div class="modal-actions"></div>
      </div>
    </div>
  </template>

  <script type="module" src="src/app.js"></script>
</body>
</html>
